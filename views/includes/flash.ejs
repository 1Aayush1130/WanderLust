<% if(locals.success && locals.success.length ) { %>
    <div class="alert alert-success alert-dismissable fade show col-6 offset-3 d-flex align-items-center justify-content-between" role="alert">
        <%= locals.success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>
<% if(locals.error && locals.error.length ) { %>
    <div class="alert alert-danger alert-dismissable fade show col-6 offset-3 d-flex align-items-center justify-content-between" role="alert">
        <%= locals.error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>
